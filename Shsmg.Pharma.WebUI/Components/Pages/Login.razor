@page "/login"
@using Shsmg.Pharma.Application.DTOs
@using Shsmg.Pharma.Application.Services
@using System.ComponentModel.DataAnnotations
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="login-shell">
    <div class="container py-4 py-lg-5">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <div class="login-frame shadow-lg">
                    <div class="row g-0 align-items-stretch">
                        <div class="col-lg-5 d-none d-lg-flex">
                            <section class="login-aside">
                                <span class="badge rounded-pill text-bg-light-subtle border border-light-subtle login-badge">Pharmacy ERP</span>
                                <h1 class="display-6 fw-bold mt-4 mb-3">Welcome back</h1>
                                <p class="lead text-white-50 mb-4">
                                    Sign in to manage invoices, company details, and day-to-day billing without extra steps.
                                </p>

                                <div class="login-feature-list">
                                    <div class="login-feature-item">
                                        <div class="login-feature-icon">1</div>
                                        <div>
                                            <h2 class="h6 mb-1">Fast invoice access</h2>
                                            <p class="mb-0 text-white-50">Jump straight into billing and open recent work quickly.</p>
                                        </div>
                                    </div>
                                    <div class="login-feature-item">
                                        <div class="login-feature-icon">2</div>
                                        <div>
                                            <h2 class="h6 mb-1">Store profile controls</h2>
                                            <p class="mb-0 text-white-50">Keep pharmacy details current for receipts and printed documents.</p>
                                        </div>
                                    </div>
                                    <div class="login-feature-item">
                                        <div class="login-feature-icon">3</div>
                                        <div>
                                            <h2 class="h6 mb-1">Simple daily workflow</h2>
                                            <p class="mb-0 text-white-50">A clean sign-in screen that stays easy to use on desktop and mobile.</p>
                                        </div>
                                    </div>
                                </div>
                            </section>
                        </div>

                        <div class="col-lg-7">
                            <section class="login-panel">
                                <div class="text-center text-lg-start mb-4">
                                    <span class="text-uppercase text-secondary fw-semibold small tracking">Secure access</span>
                                    <h2 class="h3 mt-2 mb-2">Sign in to your account</h2>
                                    <p class="text-muted mb-0">Use your registered email and password to continue.</p>
                                </div>

                                @if (!string.IsNullOrEmpty(ErrorMessage))
                                {
                                    <div class="alert alert-danger border-0 shadow-sm mb-4" role="alert">
                                        @ErrorMessage
                                    </div>
                                }

                                <form method="post" @formname="loginForm">
                                    <AntiforgeryToken />

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold" for="email">Email address</label>
                                        <input id="email"
                                               name="LoginModel.Email"
                                               type="email"
                                               autocomplete="username"
                                               placeholder="name@pharmacy.com"
                                               class="form-control form-control-lg @(Errors.ContainsKey("Email") ? "is-invalid" : "")"
                                               value="@LoginModel?.Email" />

                                        @if (Errors.ContainsKey("Email"))
                                        {
                                            <div class="invalid-feedback d-block">
                                                @foreach (var err in Errors["Email"])
                                                {
                                                    <div>@err</div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold" for="password">Password</label>
                                        <input id="password"
                                               name="LoginModel.Password"
                                               type="password"
                                               autocomplete="current-password"
                                               placeholder="Enter your password"
                                               class="form-control form-control-lg @(Errors.ContainsKey("Password") ? "is-invalid" : "")" />

                                        @if (Errors.ContainsKey("Password"))
                                        {
                                            <div class="invalid-feedback d-block">
                                                @foreach (var err in Errors["Password"])
                                                {
                                                    <div>@err</div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
                                        <div class="form-check m-0">
                                            <input id="rememberMe"
                                                   name="LoginModel.RememberMe"
                                                   type="checkbox"
                                                   class="form-check-input"
                                                   checked="@((LoginModel?.RememberMe ?? false) ? "checked" : null)" />
                                            <label class="form-check-label text-muted" for="rememberMe">
                                                Keep me signed in
                                            </label>
                                        </div>

                                        <span class="text-muted small">Authorized pharmacy staff only</span>
                                    </div>

                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg login-submit">
                                            Sign in
                                        </button>
                                    </div>
                                </form>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm]
    public LoginDto? LoginModel { get; set; }

    private Dictionary<string, List<string>> Errors = new();
    private string? ErrorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (HttpContext?.Request.Method != "POST")
            return;

        if (LoginModel is null)
        {
            ErrorMessage = "Invalid form submission.";
            return;
        }

        Errors.Clear();

        var context = new ValidationContext(LoginModel);
        var results = new List<ValidationResult>();

        if (!Validator.TryValidateObject(LoginModel, context, results, true))
        {
            foreach (var validationResult in results)
            {
                foreach (var member in validationResult.MemberNames)
                {
                    if (!Errors.ContainsKey(member))
                        Errors[member] = new List<string>();

                    Errors[member].Add(validationResult.ErrorMessage!);
                }
            }

            return;
        }

        var result = await AuthService.LoginAsync(LoginModel.Email, LoginModel.Password, LoginModel.RememberMe);

        if (result.Succeeded)
        {
            Navigation.NavigateTo("/invoices", true);
            return;
        }

        ErrorMessage = "Login failed. Please check your credentials.";
    }
}
