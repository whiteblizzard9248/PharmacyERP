@page "/company"
@attribute [Authorize(Policy = "Company.View")]

@inject IMediator Mediator
@inject NavigationManager Navigation
@inject Shsmg.Pharma.WebUI.Services.PermissionService PermissionService

<PageTitle>Store Profile</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Store Profile</h2>
            <p class="text-muted mb-0">Maintain the medical store profile used for invoice billing and receipt
                generation.</p>
            </div>
            <button class="btn btn-outline-secondary" @onclick="BackToHome">Home</button>
        </div>

        @if (IsLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        }
        else
        {
            @if (CanEditCompany)
            {
                <EditForm Model="StoreProfile" OnValidSubmit="SaveAsync">
                    @if (ValidationErrors.Any())
                    {
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                @foreach (var error in ValidationErrors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Store name</label>
                            <InputText class="form-control" @bind-Value="StoreProfile.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contact number</label>
                            <InputText class="form-control" @bind-Value="StoreProfile.ContactNumber" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <InputTextArea class="form-control" rows="4" @bind-Value="StoreProfile.Address" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">License number</label>
                            <InputText class="form-control" @bind-Value="StoreProfile.LicenseNumber" />
                        </div>
                        <div class="col-12">
                            <hr />
                            <h5>Invoice print settings</h5>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Invoice header text</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="StoreProfile.InvoiceHeaderText" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Invoice footer text</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="StoreProfile.InvoiceFooterText" />
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" id="showGst" @bind-Value="StoreProfile.PrintShowGst" />
                                <label class="form-check-label" for="showGst">Show GST on print</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" id="showExpiry"
                                               @bind-Value="StoreProfile.PrintShowExpiry" />
                                <label class="form-check-label" for="showExpiry">Show expiry on print</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" @onclick="BackToHome">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save profile</button>
                    </div>
                </EditForm>
            }
            else
            {
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Store name</label>
                        <p class="form-control-plaintext">@StoreProfile.Name</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Contact number</label>
                        <p class="form-control-plaintext">@StoreProfile.ContactNumber</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Address</label>
                        <p class="form-control-plaintext">@StoreProfile.Address</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">License number</label>
                        <p class="form-control-plaintext">@StoreProfile.LicenseNumber</p>
                    </div>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <hr />
                        <h5>Invoice print settings</h5>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Invoice header text</label>
                        <p class="form-control-plaintext">@StoreProfile.InvoiceHeaderText</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Invoice footer text</label>
                        <p class="form-control-plaintext">@StoreProfile.InvoiceFooterText</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Show GST on print</label>
                        <p class="form-control-plaintext">@(StoreProfile.PrintShowGst ? "Yes" : "No")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Show expiry on print</label>
                        <p class="form-control-plaintext">@(StoreProfile.PrintShowExpiry ? "Yes" : "No")</p>
                    </div>
                </div>
            }
        }
    </div>

@code {
    private CompanyDto StoreProfile = new CompanyDto();
    private bool IsLoading = true;
    private bool CanEditCompany;
    private List<string> ValidationErrors = new();

    protected override async Task OnInitializedAsync()
    {
        var profile = await Mediator.Send(new GetCompanyQuery());
        StoreProfile = profile ?? new CompanyDto();
        CanEditCompany = await PermissionService.HasPermissionAsync("Company.Edit");
        IsLoading = false;
    }

    private async Task SaveAsync()
    {
        ValidationErrors.Clear();

        try
        {
            await Mediator.Send(new CreateCompanyCommand(StoreProfile));
            Navigation.NavigateTo("/company", true);
        }
        catch (FluentValidation.ValidationException validationException)
        {
            ValidationErrors = validationException.Errors
                .Select(error => string.IsNullOrWhiteSpace(error.PropertyName)
                    ? error.ErrorMessage
                    : $"{error.PropertyName}: {error.ErrorMessage}")
                .Distinct()
                .ToList();
        }
        catch (Exception exception)
        {
            ValidationErrors.Add(exception.Message);
        }
    }

    private void BackToHome() => Navigation.NavigateTo("/");
}
