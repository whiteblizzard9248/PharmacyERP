@page "/inventory"
@attribute [Authorize(Policy = "Inventory.View")]
@rendermode InteractiveServer
@using Shsmg.Pharma.Application.DTOs
@using Shsmg.Pharma.Application.Services

@inject IInventoryService InventoryService
@inject NavigationManager Navigation
@inject Shsmg.Pharma.WebUI.Services.PermissionService PermissionService

<PageTitle>Inventory</PageTitle>

<div class="inventory-shell">
    <div class="container py-4 py-lg-5">
        <div class="inventory-hero mb-4">
            <div>
                <span class="text-uppercase text-secondary fw-semibold small inventory-kicker">Inventory control</span>
                <h2 class="mb-2">Inventory Management</h2>
                <p class="text-muted mb-0">Manage stock records in one place and search quickly by HSN code or batch.</p>
            </div>
            @if (CanManageInventory)
            {
                <button type="button" class="btn btn-primary inventory-add-btn" @onclick="CreateItem">Add inventory item</button>
            }
        </div>

        <section class="inventory-toolbar mb-4">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-8">
                    <label class="form-label fw-semibold" for="inventory-search">Search by HSN code or batch</label>
                    <InputText id="inventory-search"
                               class="form-control form-control-lg"
                               placeholder="Type HSN code or batch number"
                               @bind-Value="SearchQuery"
                               @bind-Value:event="oninput" />
                    <div class="form-text">Employees can view results. Admins and managers can create, edit, and soft delete items.</div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="inventory-result-count">
                        <span class="text-muted small text-uppercase fw-semibold">Results</span>
                        <div class="fs-4 fw-bold">@Items.Count</div>
                    </div>
                </div>
            </div>
        </section>

        @if (IsLoading)
        {
            <div class="inventory-panel text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        }
        else if (Items.Count == 0)
        {
            <div class="alert alert-info shadow-sm border-0">No inventory items match the current filter. Try a different HSN code or batch, or add a new stock record.</div>
        }
        else
        {
            <section class="inventory-panel">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Item</th>
                                <th>HSN code</th>
                                <th>Batch</th>
                                <th>Expiry</th>
                                <th>Stock</th>
                                <th>Rate</th>
                                <th>GST</th>
                                @if (CanManageInventory)
                                {
                                    <th style="width: 180px;">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Items)
                            {
                                <tr class="@(item.IsLowStock ? "table-warning" : null)">
                                    <td>
                                        <div class="fw-semibold">@item.Description</div>
                                        <div class="small text-muted">Reorder at @item.ReorderLevel</div>
                                    </td>
                                    <td>@item.HsnCode</td>
                                    <td>@item.Batch</td>
                                    <td>@item.ExpiryDate</td>
                                    <td>@item.QuantityInStock</td>
                                    <td>@item.Rate.ToString("C")</td>
                                    <td>@item.GstPercentage.ToString("0.##")%</td>
                                    @if (CanManageInventory)
                                    {
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-secondary me-2" @onclick="() => EditItem(item.Id)">Edit</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItemAsync(item.Id)">Delete</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
</div>

@code {
    private List<InventoryItemSummaryDto> Items = [];
    private bool IsLoading = true;
    private bool CanManageInventory;
    private string searchQuery = string.Empty;

    private string SearchQuery
    {
        get => searchQuery;
        set
        {
            if (searchQuery == value)
            {
                return;
            }

            searchQuery = value;
            _ = InvokeAsync(LoadAsync);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CanManageInventory = await PermissionService.HasAnyPermissionAsync("Inventory.Create", "Inventory.Edit", "Inventory.Delete");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        StateHasChanged();
        Items = (await InventoryService.GetInventoryItemsAsync(SearchQuery)).ToList();
        IsLoading = false;
    }

    private void CreateItem() => Navigation.NavigateTo("/inventory/new");

    private void EditItem(Guid id) => Navigation.NavigateTo($"/inventory/edit/{id}");

    private async Task DeleteItemAsync(Guid id)
    {
        await InventoryService.DeleteInventoryItemAsync(id);
        await LoadAsync();
    }
}
