@page "/users/new"
@page "/users/edit/{UserId}"
@attribute [Authorize(Policy = "User.Manage")]

@using Shsmg.Pharma.Application.Common
@using Shsmg.Pharma.Application.Services
@inject Shsmg.Pharma.Application.Services.IUserService UserService
@inject NavigationManager Navigation
@inject Shsmg.Pharma.WebUI.Services.PermissionService PermissionService
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Edit User" : "New User")</PageTitle>

<div class="user-form-shell">
    <div class="container py-4 py-lg-5">
        <div class="user-form-hero mb-4">
            <div>
                <span class="text-uppercase text-secondary fw-semibold small user-form-kicker">User access</span>
                <h2 class="mb-2">@(IsEdit ? "Edit User" : "New User")</h2>
                <p class="text-muted mb-0">@(IsEdit ? "Update access and roles for an existing team member." : "Create a new user account and assign the right access level.")</p>
            </div>
            <button type="button" class="btn btn-outline-secondary user-form-back" @onclick="BackToUsers">Back</button>
        </div>

        <EditForm Model="UserModel" OnValidSubmit="SaveAsync">
            <div class="row g-4">
                <div class="col-12 col-xl-8">
                    @if (ValidationErrors.Any())
                    {
                        <div class="alert alert-danger shadow-sm border-0 mb-4" role="alert">
                            <div class="fw-semibold mb-2">Please fix these issues before saving.</div>
                            <ul class="mb-0 ps-3">
                                @foreach (var error in ValidationErrors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    }

                    <section class="user-form-panel">
                        <div class="user-form-panel-header">
                            <div>
                                <h3 class="h5 mb-1">Account details</h3>
                                <p class="text-muted mb-0">Set the login email and, for new users, an initial password.</p>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email</label>
                                <InputText class="form-control form-control-lg" @bind-Value="UserModel.Email" disabled="@IsEdit" />
                            </div>
                            @if (!IsEdit)
                            {
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Password</label>
                                    <InputText type="password" class="form-control form-control-lg" @bind-Value="UserModel.Password" />
                                </div>
                            }
                        </div>
                    </section>

                    <section class="user-form-panel mt-4">
                        <div class="user-form-panel-header">
                            <div>
                                <h3 class="h5 mb-1">Roles</h3>
                                <p class="text-muted mb-0">Choose the permissions this user should receive.</p>
                            </div>
                        </div>

                        <div class="row g-3">
                            @foreach (var role in AvailableRoles)
                            {
                                <div class="col-md-6 col-xl-4">
                                    <label class="user-role-card" for="@role">
                                        <div class="form-check m-0">
                                            <InputCheckbox class="form-check-input"
                                                           id="@role"
                                                           Value="GetRoleValue(role)"
                                                           ValueChanged="@(v => SetRoleValue(role, v))"
                                                           ValueExpression="() => UserModel.SelectedRoles[role]" />
                                            <span class="form-check-label fw-semibold">@role</span>
                                        </div>
                                        <span class="text-muted small">Enable access for this responsibility area.</span>
                                    </label>
                                </div>
                            }
                        </div>
                    </section>
                </div>

                <div class="col-12 col-xl-4">
                    <aside class="user-form-sidecard">
                        <h3 class="h5 mb-3">Summary</h3>
                        <p class="text-muted mb-4">Keep account setup simple and assign only the roles this team member needs.</p>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">@(IsEdit ? "Update User" : "Create User")</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="BackToUsers">Cancel</button>
                        </div>
                    </aside>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public string? UserId { get; set; }

    private UserFormModel UserModel = new();
    private bool IsEdit => !string.IsNullOrEmpty(UserId);
    private List<string> ValidationErrors = new();
    private string[] AvailableRoles = new[] { Roles.Admin, Roles.Manager, Roles.Employee };

    protected override async Task OnInitializedAsync()
    {
        if (await PermissionService.IsManagerAsync())
        {
            AvailableRoles = new[] { Roles.Employee };
        }
        if (IsEdit && !string.IsNullOrEmpty(UserId))
        {
            var user = await UserService.GetUserByIdAsync(UserId);
            if (user != null)
            {
                UserModel = new UserFormModel
                {
                    Email = user.Email,
                    SelectedRoles = AvailableRoles.ToDictionary(r => r, r => user.Roles.Contains(r))
                };
            }
        }
        else
        {
            UserModel.SelectedRoles = AvailableRoles.ToDictionary(r => r, r => false);
        }
    }

    private bool GetRoleValue(string role)
    {
        return UserModel.SelectedRoles.TryGetValue(role, out var value) && value;
    }

    private void SetRoleValue(string role, bool value)
    {
        UserModel.SelectedRoles[role] = value;
    }

    private async Task SaveAsync()
    {
        ValidationErrors.Clear();

        try
        {
            var selectedRoles = UserModel.SelectedRoles.Where(kv => kv.Value).Select(kv => kv.Key).ToArray();
            if (IsEdit)
            {
                await UserService.UpdateUserAsync(UserId!, UserModel.Email, selectedRoles);
            }
            else
            {
                await UserService.CreateUserAsync(UserModel.Email, UserModel.Password, selectedRoles);
            }
            Navigation.NavigateTo("/users");
        }
        catch (Exception exception)
        {
            ValidationErrors.Add(exception.Message);
        }
    }

    private void BackToUsers() => Navigation.NavigateTo("/users");

    public class UserFormModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public Dictionary<string, bool> SelectedRoles { get; set; } = new();
    }
}
