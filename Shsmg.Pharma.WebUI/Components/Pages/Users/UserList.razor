@page "/users"
@attribute [Authorize(Policy = "User.Manage")]
@rendermode InteractiveServer

@using Shsmg.Pharma.Application.Common
@using Shsmg.Pharma.Application.Services

@inject Shsmg.Pharma.Application.Services.IUserService UserService
@inject NavigationManager Navigation
@inject Shsmg.Pharma.WebUI.Services.PermissionService PermissionService

<PageTitle>User Management</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">User Management</h2>
            <p class="text-muted mb-0">Manage users and their roles in the system.</p>
        </div>
        <button class="btn btn-primary" @onclick="CreateUser">Add User</button>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (Users?.Any() != true)
    {
        <div class="alert alert-info">No users found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Users)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>@string.Join(", ", user.Roles)</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-2"
                                        @onclick="() => EditUser(user.Id)">Edit</button>
                                @if (IsManager)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => DeleteUser(user.Id)">Delete</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IEnumerable<UserDto>? Users;
    private bool IsLoading = true;
    private bool IsManager;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
        IsManager = await PermissionService.IsManagerAsync() || await PermissionService.IsAdminAsync();
    }

    private async Task LoadUsersAsync()
    {
        Users = await UserService.GetUsersAsync();
        IsLoading = false;
    }

    private void CreateUser() => Navigation.NavigateTo("/users/new");
    private void EditUser(string id) => Navigation.NavigateTo($"/users/edit/{id}");

    private async Task DeleteUser(string id)
    {
        await UserService.DeleteUserAsync(id);
        await LoadUsersAsync();
    }
}
