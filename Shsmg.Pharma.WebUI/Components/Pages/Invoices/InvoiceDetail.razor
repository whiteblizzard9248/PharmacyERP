@page "/invoices/{InvoiceId:guid}"
@attribute [Authorize(Policy = "Invoice.View")]
@rendermode InteractiveServer

@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject PermissionService PermissionService
@using Shsmg.Pharma.Application.Services
@using Shsmg.Pharma.WebUI.Services

<PageTitle>Invoice Details</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="mb-1">Invoice Details</h2>
            <p class="text-muted mb-0">Review and update invoice details for your medical billing workflow.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToList">Back to invoices</button>
    </div>

    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (Invoice is null)
    {
        <div class="alert alert-warning">Invoice not found.</div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <p class="text-uppercase text-muted mb-1">Invoice</p>
                        <h5 class="mb-0">@Invoice.InvoiceNumber</h5>
                    </div>
                    <div class="col-md-4">
                        <p class="text-uppercase text-muted mb-1">Patient</p>
                        <p class="mb-0">@Invoice.PatientName</p>
                    </div>
                    <div class="col-md-4">
                        <p class="text-uppercase text-muted mb-1">Date</p>
                        <p class="mb-0">@Invoice.Date.ToString("dd MMM yyyy")</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p class="text-uppercase text-muted mb-1">Doctor</p>
                        <p class="mb-0">@Invoice.DoctorName</p>
                    </div>
                    <div class="col-md-6 text-end">
                        <button class="btn btn-sm btn-primary" @onclick="EditInvoice">Edit invoice</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive mb-4">
            <table class="table table-borderless align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Description</th>
                        <th>HSN/SAC</th>
                        <th>Package</th>
                        <th>Batch</th>
                        <th>Expiry</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>GST</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Invoice.Items)
                    {
                        <tr>
                            <td>@item.Description</td>
                            <td>@item.HsnCode</td>
                            <td>@item.Package</td>
                            <td>@item.Batch</td>
                            <td>@item.ExpiryDate</td>
                            <td>@item.Quantity</td>
                            <td>@item.Rate.ToString("C")</td>
                            <td>@item.GstPercentage %</td>
                            <td>@((item.TotalWithoutTax + item.GstAmount).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row">
            <div class="col-md-4 offset-md-8">
                <dl class="row">
                    <dt class="col-6">Subtotal</dt>
                    <dd class="col-6 text-end">@Invoice.GrossTotal.ToString("C")</dd>

                    <dt class="col-6">GST total</dt>
                    <dd class="col-6 text-end">@Invoice.TotalGst.ToString("C")</dd>

                    <dt class="col-6">Net total</dt>
                    <dd class="col-6 text-end fw-bold">@Invoice.NetTotal.ToString("C")</dd>
                </dl>
            </div>
        </div>
        @if (IsAdminOrManager)
        {
            <div class="card mt-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h3 class="h5 mb-1">Audit History</h3>
                            <p class="text-muted mb-0">Review who changed this invoice and when.</p>
                        </div>
                    </div>

                    @if (AuditLogs.Count == 0)
                    {
                        <div class="text-muted">No audit history recorded yet.</div>
                    }
                    else
                    {
                        <div class="d-grid gap-3">
                            @foreach (var log in AuditLogs)
                            {
                                <div class="border rounded-4 p-3 bg-light-subtle">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <div class="fw-semibold">@log.Action</div>
                                            <div class="text-muted">@log.Summary</div>
                                        </div>
                                        <div class="text-end small text-muted">
                                            <div>@log.PerformedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                                            <div>@log.PerformedBy</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public Guid InvoiceId { get; set; }
    private bool IsAdminOrManager { get; set; }

    private InvoiceDetailDto? Invoice;
    private IReadOnlyList<InvoiceAuditLogDto> AuditLogs = [];
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        Invoice = await InvoiceService.GetInvoiceByIdAsync(InvoiceId);
        AuditLogs = await InvoiceService.GetInvoiceAuditLogsAsync(InvoiceId);
        IsLoading = false;
        IsAdminOrManager = await PermissionService.IsAdminAsync() || await PermissionService.IsManagerAsync();
    }

    private void BackToList() => Navigation.NavigateTo("/invoices");
    private void EditInvoice() => Navigation.NavigateTo($"/invoices/edit/{InvoiceId}");
}
