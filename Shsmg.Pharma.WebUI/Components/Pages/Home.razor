@page "/"

<PageTitle>Home</PageTitle>

<div class="container py-5">
    <div class="p-5 rounded-4 bg-light shadow-sm">
        <h1 class="display-5 fw-bold">Medical Store Billing</h1>
        <p class="lead text-muted">Create invoices, maintain your store profile, and keep billing simple with clean MediatR-driven screens.</p>
        <div class="d-flex flex-column flex-sm-row gap-3 mt-4">
            <NavLink class="btn btn-primary btn-lg" href="invoices">Manage invoices</NavLink>
            <NavLink class="btn btn-outline-secondary btn-lg" href="company">Edit store profile</NavLink>
        </div>
    </div>

    <div class="row mt-5 gy-4">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h5">Invoice list</h3>
                    <p class="text-muted">Browse existing invoices, open details, and jump directly to editing any invoice.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h5">Store profile</h3>
                    <p class="text-muted">Keep your medical store information current for receipts, prints, and billing metadata.</p>
                </div>
            </div>
        </div>
    </div>
</div>
