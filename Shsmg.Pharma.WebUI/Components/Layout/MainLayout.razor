@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="main-shell">
        <div class="top-row">
            <div class="top-row-copy">
                <span class="top-row-label">Pharmacy ERP</span>
                <span class="top-row-subtitle">Billing, users, and store operations</span>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
        <footer class="bg-light text-center text-muted py-3 mt-auto border-top">
            <div class="container">
                <small>
                    © @DateTime.Now.Year
                    <a href="https://shreshtasmg.in" class="text-decoration-none fw-semibold" target="_blank">
                        ShreshtaSMG
                    </a>
                    . All rights reserved.
                </small>
            </div>
        </footer>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
